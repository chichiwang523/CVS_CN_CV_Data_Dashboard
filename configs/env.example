# 应用运行环境
APP_ENV=production
APP_HOST=127.0.0.1
PLATFORM_URL=http://139.224.204.17
STREAMLIT_PORT=8501
API_PORT=8000

# 项目路径
PROJECT_ROOT=/srv/china-cv-agent/app
CACHE_DIR=/srv/china-cv-agent/app/cache
DATA_DIR=/srv/china-cv-agent/app/CVdata
OUTPUT_DIR=/srv/china-cv-agent/app/output

# OSS 同步配置（可选）
OSS_BUCKET=oss://your-bucket-name/china-cv-agent
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com

# 同步策略
# only_cache: 仅同步 parquet cache
# full: 同步 cache + CVdata
SYNC_MODE=only_cache

# SMTP — 阿里云 DirectMail 邮件通知（管理员审批通知）
# 未配置时降级为仅面板审批，不发送邮件
SMTP_HOST=smtpdm.aliyun.com
SMTP_PORT=465
SMTP_USER=noreply@your-directmail-domain.com
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@your-directmail-domain.com
